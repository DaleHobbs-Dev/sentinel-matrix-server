{
	"info": {
		"_postman_id": "a1b2c3d4-1111-4f5e-9a8b-000000000001",
		"name": "Student Risk Dashboard API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"description": "API collection for the Student Risk Dashboard capstone. Grows as new endpoints are added — re-export from Postman and overwrite this file each time."
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 201) {",
									"    const data = pm.response.json();",
									"    pm.environment.set('authtoken', data.token);",
									"    console.log('authtoken saved:', data.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"password\": \"Admin8*Password\",\n    \"email\": \"jane.doe@example.com\",\n    \"first_name\": \"Jane\",\n    \"last_name\": \"Doe\",\n    \"bio\": \"\",\n    \"profile_picture\": \"\",\n    \"subject_taught\": \"Algebra I\",\n    \"university\": \"\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"register"
							]
						},
						"description": "Create a new instructor account.\n\nRequired: password, email, first_name, last_name.\nOptional: bio, profile_picture, subject_taught, university.\n\nReturns 201 with { token, user } on success. Validation errors (duplicate email, weak password) return 400 with field-level messages."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    const data = pm.response.json();",
									"    pm.environment.set('authtoken', data.token);",
									"    console.log('authtoken saved:', data.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"password\": \"Admin8*Password\",\n    \"email\": \"jane.doe@example.com\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"login"
							]
						},
						"description": "Authenticate an existing user.\n\nReturns 200 with { token, user } on success. Invalid credentials or inactive account return a 400 with a validation error message."
					},
					"response": []
				}
			]
		},
		{
			"name": "Students",
			"item": [
				{
					"name": "List Students",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/students",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"students"
							]
						},
						"description": "Returns a list of all students ordered by last name then first name.\n\nRequires authentication. Returns 200 with an array of student objects, each containing: id, first_name, last_name, student_id, email, prior_academic_standing, enrollment_date."
					},
					"response": []
				},
				{
					"name": "Search Students",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/students?search=",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"students"
							],
							"query": [
								{
									"key": "search",
									"value": ""
								}
							]
						},
						"description": "Filters the student list by a search string. Matches against first_name, last_name, student_id, and email (case-insensitive).\n\nRequires authentication. Returns 200 with a filtered array. If no students match, returns an empty array."
					},
					"response": []
				},
				{
					"name": "Get Student by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/students/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"students",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": ""
								}
							]
						},
						"description": "Returns a single student by their primary key.\n\nRequires authentication. Returns 200 with the student object on success. Returns 404 with { \"detail\": \"Student not found.\" } if no student exists with that ID."
					},
					"response": []
				}
			]
		},
		{
			"name": "Courses",
			"item": [
				{
					"name": "List Courses",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/courses",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"courses"
							]
						},
						"description": "Returns a list of all courses.\n\nRequires authentication. Returns 200 with an array of course objects."
					},
					"response": []
				},
				{
					"name": "Get Course by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/courses/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"courses",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "1"
								}
							]
						},
						"description": "Returns a single course by its primary key.\n\nRequires authentication. Returns 200 with the course object or 404 if the course does not exist."
					},
					"response": []
				},
				{
					"name": "Search Courses",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/courses?search=calculus",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"courses"
							],
							"query": [
								{
									"key": "search",
									"value": "calculus"
								}
							]
						},
						"description": "Filters courses by a case-insensitive search string. Matches against the course name and description.\n\nRequires authentication. Returns 200 with a filtered array."
					},
					"response": []
				},
				{
					"name": "Create Course",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"course_name\": \"Introduction to Literature\",\n    \"description\": \"An introductory course exploring fiction, poetry, drama, and literary analysis.\",\n    \"term\": \"Spring 2026\",\n    \"course_image_url\": \"https://picsum.photos/seed/introduction-to-literature/800/500\",\n    \"is_active\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/courses",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"courses"
							]
						},
						"description": "Creates a course owned by the authenticated user. The instructor field is assigned from the authentication token and should not be included in the body.\n\nReturns 201 on success or 400 for invalid fields."
					},
					"response": []
				},
				{
					"name": "Replace Course",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"course_name\": \"College Algebra\",\n    \"description\": \"An updated introduction to equations, functions, graphs, and algebraic models.\",\n    \"term\": \"Spring 2026\",\n    \"course_image_url\": \"https://picsum.photos/seed/college-algebra-updated/800/500\",\n    \"is_active\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/courses/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"courses",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "1"
								}
							]
						},
						"description": "Replaces all editable fields on a course. Only the instructor who owns the course can update it.\n\nReturns 200 on success, 403 for a non-owner, 404 if missing, or 400 for invalid fields."
					},
					"response": []
				},
				{
					"name": "Partially Update Course",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"is_active\": false\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/courses/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"courses",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "1"
								}
							]
						},
						"description": "Updates only the supplied course fields. Only the instructor who owns the course can update it.\n\nReturns 200 on success, 403 for a non-owner, 404 if missing, or 400 for invalid fields."
					},
					"response": []
				},
				{
					"name": "Delete Course",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Token {{authtoken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/courses/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"courses",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "1"
								}
							]
						},
						"description": "Deletes a course. Only the instructor who owns the course can delete it.\n\nReturns 204 on success, 403 for a non-owner, or 404 if the course does not exist."
					},
					"response": []
				}
			]
		}
	]
}
